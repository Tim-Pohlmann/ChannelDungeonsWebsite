@page "/"
@page "/{ChannelName}"
@using System.Collections.ObjectModel
@using Microsoft.AspNetCore.Components.Web
@using ChannelDungeons.BlazorWasm.Components.Layout
@using ChannelDungeons.BlazorWasm.Components.Channel
@inject ChannelService ChannelService
@inject MessageAnimationService AnimationService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Channel Dungeons</PageTitle>

<div class="discord-app">
    <Sidebar 
        CurrentChannel="@currentChannel?.Id" 
        IsVisible="@isSidebarVisible"
        OnChannelSelected="@HandleChannelSelected"
        Channels="@channels" />
    
    <div class="content-area" class:sidebar-visible="@isSidebarVisible">
        @if (currentChannel != null)
        {
            <ChannelHeader 
                ChannelName="@currentChannel.Name"
                Description="@currentChannel.Description"
                OnToggleSidebar="@HandleToggleSidebar" />
            
            <div class="message-area">
                <MessagesList 
                    Messages="@displayedMessages"
                    ShowTypingIndicator="@showTypingIndicator" />
            </div>
            
            <footer>
                <CommandInput 
                    IsVisible="@inputVisible"
                    OnCommandSubmit="@HandleCommandSubmit" />
            </footer>
        }
        else if (isLoading)
        {
            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--discord-muted-text);">
                <p>Loading channel...</p>
            </div>
        }
        else
        {
            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--discord-muted-text);">
                <p>Channel not found.</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? ChannelName { get; set; }

    private List<Channel> channels = new();
    private Channel? currentChannel;
    private List<Message> displayedMessages = new();
    private bool showTypingIndicator = false;
    private bool isSidebarVisible = false;
    private bool inputVisible = false;
    private bool isLoading = false;
    private CancellationTokenSource? animationCts;
    private AppConfig? config;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            channels = await ChannelService.GetAllChannelsAsync();
            config = await ChannelService.GetConfigAsync();
            
            await LoadChannelAsync(ChannelName ?? channels.FirstOrDefault()?.Id);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading channels: {ex.Message}");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ChannelName) && currentChannel?.Id != ChannelName)
        {
            await LoadChannelAsync(ChannelName);
        }
    }

    private async Task LoadChannelAsync(string? channelId)
    {
        if (string.IsNullOrEmpty(channelId))
        {
            return;
        }

        var previousCts = animationCts;
        animationCts = new CancellationTokenSource();
        if (previousCts != null)
        {
            await previousCts.CancelAsync();
            previousCts.Dispose();
        }

        isLoading = true;
        displayedMessages.Clear();
        showTypingIndicator = false;
        inputVisible = false;

        try
        {
            currentChannel = await ChannelService.GetChannelAsync(channelId);
            
            if (currentChannel == null)
            {
                isLoading = false;
                return;
            }

            var cachedMessages = ChannelService.GetCachedMessages(currentChannel.Id);
            if (cachedMessages != null)
            {
                displayedMessages = cachedMessages;
                inputVisible = true;
                isLoading = false;
                return;
            }

            if (config != null)
            {
                var token = animationCts.Token;
                await Task.Delay(config.UiShowDelay, token);

                var messagesToAnimate = currentChannel.Messages.Select(m => new Message
                {
                    Username = m.Username,
                    Content = m.Content,
                    TypingDuration = m.TypingDuration,
                    Delay = m.Delay,
                    Timestamp = GetCurrentTime()
                }).ToList();

                await AnimationService.AnimateMessagesAsync(
                    messagesToAnimate,
                    async (messageIndex) =>
                    {
                        displayedMessages.Add(messagesToAnimate[messageIndex]);
                        await InvokeAsync(StateHasChanged);

                        if (SidebarAnimationService.ShouldShowSidebar(messageIndex, messagesToAnimate.Count))
                        {
                            try
                            {
                                await Task.Delay(config.UiShowDelay, token);
                                isSidebarVisible = true;
                                await InvokeAsync(StateHasChanged);
                            }
                            catch (OperationCanceledException)
                            {
                                // Expected when navigating away
                            }
                        }
                    },
                    async (isTyping) =>
                    {
                        showTypingIndicator = isTyping;
                        await InvokeAsync(StateHasChanged);
                    },
                    config,
                    token);

                ChannelService.CacheMessages(currentChannel.Id, displayedMessages);
                inputVisible = true;
            }
        }
        catch (OperationCanceledException)
        {
            // Expected when navigating away
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleChannelSelected(string channelId)
    {
        isSidebarVisible = false;
        await LoadChannelAsync(channelId);
        NavigationManager.NavigateTo($"/{channelId}");
    }

    private void HandleToggleSidebar()
    {
        isSidebarVisible = !isSidebarVisible;
    }

    private async Task HandleCommandSubmit(string command)
    {
        if (command.StartsWith('/'))
        {
            var channelName = command[1..].ToLowerInvariant();
            var channel = channels.FirstOrDefault(c => 
                c.Name.Equals(channelName, StringComparison.OrdinalIgnoreCase));
            
            if (channel != null)
            {
                await HandleChannelSelected(channel.Id);
            }
        }
    }

    private static string GetCurrentTime()
    {
        return DateTime.Now.ToString("HH:mm");
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        animationCts?.Cancel();
        animationCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
