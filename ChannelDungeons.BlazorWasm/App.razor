<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Components.Layout.MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(Components.Layout.MainLayout)">
            <div class="message">
                <h1>Not found</h1>
                <p>Sorry, the channel you're looking for doesn't exist.</p>
                <p><a href="/">Go to welcome channel</a></p>
            </div>
        </LayoutView>
    </NotFound>
</Router>
