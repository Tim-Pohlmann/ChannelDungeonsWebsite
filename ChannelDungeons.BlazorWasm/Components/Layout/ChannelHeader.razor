@namespace ChannelDungeons.BlazorWasm.Components.Layout
@using Microsoft.AspNetCore.Components.Web

<header class="channel-header">
    <button class="sidebar-toggle" @onclick="@HandleToggleSidebar" type="button" title="Toggle sidebar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
    </button>

    <div class="channel-name">
        <span class="channel-hash">#</span>
        <span>@ChannelName</span>
    </div>

    @if (!string.IsNullOrEmpty(Description))
    {
        <div class="channel-description">
            @Description
        </div>
    }
</header>

@code {
    [Parameter]
    public string ChannelName { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }

    private async Task HandleToggleSidebar()
    {
        await OnToggleSidebar.InvokeAsync();
    }
}
