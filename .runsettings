<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage" assemblyQualifiedName="Coverlet.Collector.DataCollection.CoverletRunSettings, coverlet.collector">
        <Configuration>
          <!-- Include the BlazorWasm project in coverage -->
          <Include>[ChannelDungeons.BlazorWasm]*</Include>

          <!-- Exclude generated code and test files -->
          <Exclude>[ChannelDungeons.Tests]*</Exclude>
          <Exclude>[*.Tests]*</Exclude>

          <!-- Exclude compiler-generated code -->
          <ExcludeByAttribute>System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>

          <!-- Output in OpenCover format for SonarQube -->
          <Format>opencover</Format>

          <!-- Skip coverage for synthetic methods -->
          <SkipAutoProps>true</SkipAutoProps>
          <DeterministicReport>true</DeterministicReport>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
